<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="false">

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <appender name="OTLP_HTTP" class="com.maislog.MaislogAppender">
    <endpoint>https://maislog.dev/api/v1/writer/logs</endpoint>
    <token>${MAISLOG_TOKEN}</token>
    <serviceName>originhub</serviceName>
  </appender>

  <root level="WARN">
    <appender-ref ref="STDOUT"/>
    <appender-ref ref="OTLP_HTTP"/>
  </root>
</configuration>
