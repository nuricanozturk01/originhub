## app.config.ts

```typescript
import { ApplicationConfig } from '@angular/core';
import { provideRouter } from '@angular/router';
import { provideHttpClient, withInterceptors } from '@angular/common/http';
import { routes } from './app.routes';
import { authInterceptor } from './core/auth/interceptors/auth.interceptor';
import { refreshInterceptor } from './core/auth/interceptors/refresh.interceptor';
import { mockInterceptor } from './mock/mock.interceptor';
import { MOCK_CONFIG } from './mock/mock.config';

export const appConfig: ApplicationConfig = {
  providers: [
    provideRouter(routes),
    provideHttpClient(
      withInterceptors([
        // Mock interceptor en başta — mock açıksa gerçek istek gitmez
        ...(MOCK_CONFIG.enabled ? [mockInterceptor] : []),
        authInterceptor,
        refreshInterceptor,
      ]),
    ),
  ],
};
```

