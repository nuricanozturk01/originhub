## Mock Data Sistemi

### mock.config.ts
```typescript
// Bu dosyayı değiştirerek mock'u açıp kapatabilirsin
export const MOCK_CONFIG = {
  enabled: true,           // FALSE yapınca gerçek API'ye geçer
  delay: 400,              // ms — gerçekçi network gecikmesi simüle eder
  simulateErrors: false,   // TRUE yapınca rastgele 500 hataları fırlatır
};
```

### mock.interceptor.ts
```typescript
import { HttpInterceptorFn, HttpResponse } from '@angular/common/http';
import { of, delay } from 'rxjs';
import { MOCK_CONFIG } from './mock.config';
import { AUTH_HANDLERS } from './handlers/auth.handler';
import { REPO_HANDLERS } from './handlers/repo.handler';
import { BRANCH_HANDLERS } from './handlers/branch.handler';
import { COMMIT_HANDLERS } from './handlers/commit.handler';
import { PR_HANDLERS } from './handlers/pull-request.handler';
import { WORKFLOW_HANDLERS } from './handlers/workflow.handler';

// Tüm handler'lar bir arada
const ALL_HANDLERS = [
  ...AUTH_HANDLERS,
  ...REPO_HANDLERS,
  ...BRANCH_HANDLERS,
  ...COMMIT_HANDLERS,
  ...PR_HANDLERS,
  ...WORKFLOW_HANDLERS,
];

export const mockInterceptor: HttpInterceptorFn = (req, next) => {
  if (!MOCK_CONFIG.enabled) {
    return next(req);
  }

  const handler = ALL_HANDLERS.find(
    (h) => h.method === req.method && new RegExp(h.urlPattern).test(req.url),
  );

  if (!handler) {
    // Handler bulunamazsa gerçek API'ye gönder
    return next(req);
  }

  const responseBody = handler.response(req);

  return of(new HttpResponse({ status: 200, body: responseBody })).pipe(
    delay(MOCK_CONFIG.delay),
  );
};
```

### Handler Tipi

```typescript
// src/app/mock/handler.type.ts
import { HttpRequest } from '@angular/common/http';

export interface MockHandler {
  method: string;                                    // 'GET', 'POST', 'PATCH', 'DELETE'
  urlPattern: string;                                // regex string
  response: (req: HttpRequest<unknown>) => unknown;  // döndürülecek data
}
```

